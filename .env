# InfluxDB
INFLUXDB_DB=shellydb
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminpassword

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Polling
POLL_INTERVAL=60
REQUEST_TIMEOUT=15
INFLUX_MEASUREMENT=shelly_power

# Optional global Shelly basic auth
SHELLY_USERNAME=
SHELLY_PASSWORD=

# Simple format: name@ip_or_url,name@ip_or_url
# Example:
# SHELLY_DEVICES=plug_kitchen@192.168.1.101,plug_office@192.168.1.102,plug_server@http://192.168.1.103
SHELLY_DEVICES=plug1@192.168.0.59

# Advanced JSON format if you need per-device generation or switch id.
# Leave empty when using SHELLY_DEVICES.
# Example:
# SHELLY_DEVICES_JSON=[
#   {"name":"plug1","url":"http://192.168.1.101","generation":"auto","switch_id":0},
#   {"name":"plug2","url":"http://192.168.1.102","generation":"gen2","switch_id":0}
# ]
SHELLY_DEVICES_JSON=
